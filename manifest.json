{
  "manifest_version": 3,
  "name": "МЫШЬ",
  "version": "1.2",
  "description": "Extension to mesh",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://school.mos.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "МЫШЬ"
  },
  "content_scripts": [
    {
      "matches": ["https://school.mos.ru/*"],
      "js": ["content.js"]
    }
  ]
}